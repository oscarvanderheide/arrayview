{
  "name": "arrayview-opener",
  "displayName": "ArrayView Opener",
  "description": "Opens ArrayView in VS Code and can promote tunnel ports to public preview",
  "version": "0.14.3",
  "publisher": "arrayview",
  "license": "MIT",
  "icon": "icon.png",
  "engines": { "vscode": "^1.80.0" },
  "extensionKind": ["workspace", "ui"],
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/oscarvanderheide/arrayview.git"
  },
  "files": [
    "extension.js",
    "package.json",
    "icon.png",
    "LICENSE"
  ],
  "contributes": {
    "configuration": {
      "title": "ArrayView",
      "properties": {
        "arrayview.openInFloatingWindow": {
          "type": "boolean",
          "default": false,
          "description": "Open ArrayView tabs in a floating window."
        }
      }
    },
    "commands": [
      {
        "command": "arrayview.openFile",
        "title": "Open in ArrayView"
      }
    ],
    "customEditors": [
      {
        "viewType": "arrayview.arrayEditor",
        "displayName": "ArrayView",
        "selector": [
          { "filenamePattern": "*.npy" },
          { "filenamePattern": "*.npz" },
          { "filenamePattern": "*.nii" },
          { "filenamePattern": "*.nii.gz" },
          { "filenamePattern": "*.h5" },
          { "filenamePattern": "*.hdf5" },
          { "filenamePattern": "*.mat" },
          { "filenamePattern": "*.tif" },
          { "filenamePattern": "*.tiff" },
          { "filenamePattern": "*.pt" },
          { "filenamePattern": "*.pth" },
          { "filenamePattern": "*.zarr.zip" }
        ],
        "priority": "default"
      }
    ]
  }
}
